################################################################################
# LuckyDraw — Telegram Mini App (Laravel + Livewire)
# Target: shared hosting (cPanel) + MySQL + cron + Telegram webhook
#
# Copy to .env, then:  php artisan key:generate
################################################################################

APP_NAME=LuckyDraw
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Public HTTPS URL of your site (docroot must point to /public)
APP_URL=https://yourdomain.com

# UI language: en (English) or am (Amharic)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Database — use the MySQL database from your cPanel (Postgres NOT required).
# For quick LOCAL testing you can instead set: DB_CONNECTION=sqlite
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_luckydraw
DB_USERNAME=cpaneluser_lucky
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Sessions / queue / cache — all DB-backed so NO Redis or extra services are
# needed on shared hosting. The queue is drained by a cron job (see README).
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Telegram opens the Mini App in an embedded webview; SameSite must allow it.
# Both lines are REQUIRED (and your site must be HTTPS).
SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================================================
# Telegram Bot — from @BotFather
# ===========================================================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyz
TELEGRAM_BOT_USERNAME=YourLuckyDrawBot

# Public HTTPS URL Telegram loads as the Mini App (usually = APP_URL).
MINI_APP_URL="${APP_URL}"

# Telegram user id(s) allowed to use the /admin BOT COMMAND. Comma-separate
# for multiple admins. Get yours from @userinfobot.
ADMIN_TELEGRAM_ID=123456789

# Optional: channel/group where winner results are posted (@name or -100…).
# The bot must be an admin of the channel. Leave blank to skip channel posts.
TELEGRAM_CHANNEL_ID=

# ===========================================================================
# Admin panel (browser-only, password protected) — the operator dashboard at
# /admin. This is SEPARATE from the Telegram /admin bot command above.
# ===========================================================================
ADMIN_PANEL_USERNAME=youradmin
# REQUIRED in production: a BCRYPT hash (not the plaintext password). Generate:
#   php artisan tinker --execute="echo bcrypt('your-strong-password');"
ADMIN_PANEL_PASSWORD_HASH=
# Plaintext fallback for first-run/local only. Leave blank in production and
# use ADMIN_PANEL_PASSWORD_HASH instead.
ADMIN_PANEL_PASSWORD=

# ===========================================================================
# Gameplay
# ===========================================================================
LOTTERY_CURRENCY=ETB
# Seconds of suspense between locking sales and revealing the winner.
LOTTERY_DRAW_SUSPENSE=10
# Free tickets a referrer earns when a referred player first buys.
LOTTERY_REFERRAL_REWARD=1
# Max numbers a single buyer may pick in one purchase.
LOTTERY_MAX_PER_PURCHASE=20
# Also DM every known player when a new round starts (noisy; off by default).
# New rounds are always posted to TELEGRAM_CHANNEL_ID regardless.
LOTTERY_ANNOUNCE_PLAYERS=false

# ===========================================================================
# Wallet & payments — verify.leul.et (https://verifyapi.leulzenebe.pro)
# Deposits are auto-verified against a real Telebirr/CBE/M-Pesa transaction.
# Get an API key from the verify.leul.et dashboard. Leave VERIFY_API_KEY blank
# to disable deposits entirely.
# ===========================================================================
VERIFY_API_URL=https://verifyapi.leulzenebe.pro
VERIFY_API_KEY=
# Your receiving account name(s)/number(s); a deposit only counts if its
# verified receiver matches one of these. Comma-separated. STRONGLY recommended
# — without it, ANY verified payment is credited regardless of who it was paid to.
DEPOSIT_ACCOUNTS=
LOTTERY_MIN_DEPOSIT=10
LOTTERY_MIN_WITHDRAW=50
LOTTERY_DEPOSIT_INSTRUCTIONS="Send the amount to our Telebirr/CBE account, then paste the transaction reference below."

# ===========================================================================
# Local dev only — impersonate a Telegram user in a normal browser so you can
# test outside Telegram. Leave ALL of these BLANK in production.
# (Only takes effect when APP_ENV=local.)
# ===========================================================================
DEV_TELEGRAM_ID=
DEV_TELEGRAM_NAME="Dev Tester"
# DEV_TELEGRAM_PHONE=

VITE_APP_NAME="${APP_NAME}"
